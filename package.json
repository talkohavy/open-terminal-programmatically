{
  "name": "open-terminal-programmatically",
  "version": "1.2.0",
  "description": "A support package for the vscode extension `Open Terminal Programmatically`",
  "private": "true",
  "main": "index.esm.mjs",
  "module": "index.esm.mjs",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./types/index.d.ts",
        "default": "./index.esm.mjs"
      },
      "require": {
        "types": "./types/index.d.ts",
        "default": "./index.cjs.cjs"
      }
    }
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "tsc": "tsc -p tsconfig.json",
    "format": "biome format ./src",
    "format:fix": "biome format --verbose ./src --write",
    "test": "node --test",
    "build": "node ./build.config.mjs",
    "prepare": "husky install"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/talkohavy/open-terminal-package"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "restricted"
  },
  "contributors": [
    {
      "name": "Tal Kohavy",
      "email": "talkohavy@gmail.com",
      "url": "https://github.com/talkohavy"
    }
  ],
  "bugs": {
    "author": "Tal Kohavy",
    "license": "MIT",
    "url": "https://github.com/talkohavy/open-terminal-package/issues",
    "email": "talkohavy@gmail.com"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lvlup": "^1.2.0",
    "prettier": "^3.8.3",
    "rollup": "^4.61.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "open-terminal-programmatically": "link:"
  }
}
